generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BoardScope {
  UNIVERSITY
  NATIONAL
}

enum BoardCategory {
  CONSULT
  RECRUIT
  QUESTION
  TWEET
  ANNOUNCEMENT
}

enum CircleMemberRole {
  MEMBER
  ADMIN
}

enum ConversationType {
  DIRECT
  GROUP
}

model University {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  emailDomain String    @unique
  profiles    Profile[]
  posts       BoardPost[]
  circles     Circle[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Profile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique

  university   University @relation(fields: [universityId], references: [id])
  universityId String

  realName    String
  studentId   String?
  grade       String?
  major       String?
  affiliation String?
  title       String?

  bio       String?
  instagram String?
  x         String?
  tiktok    String?
  website   String?

  posts         BoardPost[]
  replies       BoardReply[]
  circleMembers CircleMember[]
  circleMessages CircleMessage[]
  conversationParticipants ConversationParticipant[]
  messages      Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([universityId])
}

model BoardPost {
  id           String        @id @default(cuid())
  scope        BoardScope
  category     BoardCategory
  content      String

  university   University? @relation(fields: [universityId], references: [id])
  universityId String?

  author   Profile @relation(fields: [authorProfileId], references: [id])
  authorProfileId String

  replies   BoardReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, universityId, category, createdAt])
  @@index([authorProfileId, createdAt])
}

model BoardReply {
  id      String   @id @default(cuid())
  content String

  post   BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  author Profile @relation(fields: [authorProfileId], references: [id])
  authorProfileId String

  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([authorProfileId, createdAt])
}

model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(true)

  university   University? @relation(fields: [universityId], references: [id])
  universityId String?

  members  CircleMember[]
  messages CircleMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([universityId])
}

model CircleMember {
  id        String           @id @default(cuid())
  role      CircleMemberRole @default(MEMBER)

  circle   Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  circleId String

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  joinedAt DateTime @default(now())

  @@unique([circleId, profileId])
  @@index([profileId])
}

model CircleMessage {
  id       String  @id @default(cuid())
  body     String
  mediaUrl String?

  circle   Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)
  circleId String

  sender   Profile @relation(fields: [senderProfileId], references: [id])
  senderProfileId String

  createdAt DateTime @default(now())

  @@index([circleId, createdAt])
}

model Conversation {
  id    String           @id @default(cuid())
  type  ConversationType
  title String?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  joinedAt DateTime @default(now())

  @@unique([conversationId, profileId])
  @@index([profileId])
}

model Message {
  id             String       @id @default(cuid())
  body           String
  mediaUrl       String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  sender   Profile @relation(fields: [senderProfileId], references: [id])
  senderProfileId String

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model JobPost {
  id          String   @id @default(cuid())
  company     String
  title       String
  description String
  url         String?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

